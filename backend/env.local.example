# Backend Environment Variables (Local Development with Supabase)
# Copy this to backend/.env and fill in the values from `npx supabase start`

APP_ENV=development
DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:54322/postgres
ALLOW_INSECURE_DEV_AUTH=false
FRONTEND_URL=http://localhost:5173

# Supabase Auth (get these from `npx supabase start` output)
SUPABASE_JWT_SECRET=your_local_jwt_secret_here
SUPABASE_JWT_AUDIENCE=authenticated

# LLM Provider (choose one or configure all)
LLM_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# XAI_API_KEY=your_xai_api_key_here

# LLM Models
LLM_PROJECT_MODEL=gemini-1.5-pro
LLM_RUN_MODEL=gemini-1.5-flash

# LLM Pricing (cents per million tokens)
LLM_INPUT_COST_PER_MILLION_CENTS=125
LLM_OUTPUT_COST_PER_MILLION_CENTS=500

# Stripe (optional for local testing)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_ID_PRO=price_...
